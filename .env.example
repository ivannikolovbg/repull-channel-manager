# --- Database ---
# Postgres connection string. Works with Vercel Postgres, Neon, Supabase, or any plain Postgres.
# Local dev: spin up via `docker compose up -d` then use the value below.
DATABASE_URL=postgres://repull:repull@localhost:5432/repull_cm

# --- Auth (NextAuth) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-32-byte-base64-string
# Where the app is publicly reachable. Locally: http://localhost:3030
AUTH_URL=http://localhost:3030

# Email magic-link provider (NextAuth). Free tier: Resend works great.
# Leave blank in dev to use the console email transport (link printed to server logs).
EMAIL_SERVER=smtp://user:pass@smtp.resend.com:587
EMAIL_FROM=Repull Channel Manager <noreply@example.com>

# --- Repull API ---
# Override only if you're hitting a non-prod Repull instance.
REPULL_API_BASE_URL=https://api.repull.dev

# --- Webhook signing ---
# Used to verify incoming Repull webhook signatures. Get one from Repull dashboard.
WEBHOOK_SIGNING_SECRET=replace-me

# --- Cron auth ---
# Vercel Cron requests carry `Authorization: Bearer ${CRON_SECRET}` when this is set.
# Generate with: openssl rand -base64 32
CRON_SECRET=replace-me

# --- Workspace API key encryption (optional) ---
# 32-byte base64 key used to encrypt per-workspace Repull API keys at rest.
# If unset, keys are stored as plaintext (fine for local dev, NOT for production).
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# --- Demo workspace (optional) ---
# Real Repull API key applied to the seeded `demo@repull.dev` workspace on
# every demo signin. When unset, the demo workspace gets a placeholder key
# and "Connect a channel" returns 401 from Repull.
DEMO_REPULL_API_KEY=

# When set to "off", the one-click demo button on /sign-in returns 404.
DEMO_SIGNIN=
